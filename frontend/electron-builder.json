{
  "appId": "com.ai-novelist.app",
  "productName": "青烛",
  "directories": {
    "output": "../dist"
  },
  "asar": true,
  "asarUnpack": [
    "main.py",
    "backend/**/*",
    "static/**/*"
  ],
  "files": [
    "electron/**/*",
    "package.json",
    {
      "from": "../dist/frontend",
      "to": ".",
      "filter": ["**/*"]
    },
    "../main.py",
    "../backend/**/*",
    "../static/**/*",
    "../.env.example"
  ],
  "extraResources": [
    {
      "from": "../dist/portable/python",
      "to": "python",
      "filter": ["**/*"]
    },
    {
      "from": "../dist/portable/bin",
      "to": "bin",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "assets/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "perMachine": true,
    "installerIcon": "assets/icon.ico",
    "uninstallerIcon": "assets/icon.ico",
    "installerHeader": "assets/icon.ico",
    "installerSidebar": "assets/icon.ico",
    "deleteAppDataOnUninstall": true,
    "runAfterFinish": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "青烛"
  },
  "portable": {
    "artifactName": "青烛-便携版-${version}.exe"
  }
}
